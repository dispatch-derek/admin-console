# AnythingLLM engine (sealed dependency) — REQ-001, REQ-013
ANYTHINGLLM_BASE_URL=http://localhost:3001
ANYTHINGLLM_API_KEY=

# Admin BFF — REQ-020
PORT=3002
LOG_LEVEL=info

# First-account bootstrap — REQ-019a
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_TOKEN=

# Session cookie signing + secrets-at-rest encryption
SESSION_SECRET=
SECRETS_ENC_KEY=

# BFF store
DB_PATH=data/console.db

# CORS strict allowlist (production) — REQ-095
WEB_ORIGINS=

# Event bus (interim outbox; real bus optional) — design 04c
EVENT_BUS_MODE=inproc
EVENT_BUS_URL=
# Shared-secret credential attached to every outbound peer POST (F-010 REQ-F010-007/020).
# Provisioned by the deployment operator; leave EMPTY here — never commit a real secret.
# Read as a raw single string (no trim/split applied at boot). NOTE: leading/trailing
# whitespace is NOT reliably transmitted (WHATWG Fetch strips HTTP whitespace); do not depend
# on padding whitespace. In production a configured peer with this unset/empty refuses to boot.
EVENT_BUS_PEER_AUTH_TOKEN=
