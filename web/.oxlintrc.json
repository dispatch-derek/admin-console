{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "error",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": [
              "**/design-system/components/**"
            ],
            "message": "Import design-system components from the barrel 'design-system' (index.ts), not component internals."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "src/design-system/index.ts",
        "src/design-system/index.tsx"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "ignorePatterns": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/test/**",
    "**/tests/**",
    "vendor/**",
    "dist/**"
  ]
}
